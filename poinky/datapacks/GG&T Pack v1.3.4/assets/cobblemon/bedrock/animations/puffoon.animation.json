{
	"format_version": "1.8.0",
	"animations": {
		"animation.puffoon.air_idle": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": ["-0-Math.cos((query.anim_time)*90*1-90)*2", "-0-Math.cos((query.anim_time)*90*0.5-90)*5", "0+Math.cos((query.anim_time)*90*0.5)*5"],
					"position": [0, "2+Math.cos((query.anim_time)*90*1)*1", 0]
				},
				"wing_left": {
					"rotation": ["-0-Math.cos((query.anim_time)*90*4-90)*20", 0, "15+Math.cos((query.anim_time)*90*4)*40"]
				},
				"wing_right": {
					"rotation": ["-0-Math.cos((query.anim_time)*90*4-90)*20", 0, "-15-Math.cos((query.anim_time)*90*4)*40"]
				},
				"tail": {
					"rotation": [0, "-0-Math.cos((query.anim_time)*90*4-90)*10", 0]
				}
			}
		},
		"animation.puffoon.air_fly": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": ["-0-Math.cos((query.anim_time)*90*4-90)*-3", "-0-Math.cos((query.anim_time)*90*8)*-2", "0+Math.cos((query.anim_time)*90*1-90)*6"],
					"position": ["-0-Math.cos((query.anim_time)*90*1)*3", "2+Math.cos((query.anim_time)*90*4)*1", 0]
				},
				"wing_left": {
					"rotation": ["-0-Math.cos((query.anim_time)*90*16-90)*30", 0, "25-Math.cos((query.anim_time)*90*16)*30"]
				},
				"wing_right": {
					"rotation": ["-0-Math.cos((query.anim_time)*90*16-90)*30", 0, "-25+Math.cos((query.anim_time)*90*16)*30"]
				},
				"tail": {
					"rotation": ["-0-Math.cos((query.anim_time)*90*4-90)*-10", "-0-Math.cos((query.anim_time)*90*8)*-10", 0]
				}
			}
		},
		"animation.puffoon.ride_air_idle": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": ["-0-q.r.input_forward*-20", 0, "0+q.r.input_right*-20"]
				}
			}
		},
		"animation.puffoon.ride_air_fly": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": [0, "-0-q.r.yaw_change*-10", 0]
				},
				"tail": {
					"rotation": [0, "-0-q.r.yaw_change*30", 0]
				}
			}
		}
	}
}