{
  "head": "head",
  "portraitScale": 1.6,
  "portraitTranslation": [-0.5, 0, 0],
  "profileScale": 0.6,
  "profileTranslation": [0.1, 0.8, 0],
  "poses": {
    "standing": {
      "poseName": "standing",
	  "condition": "q.has_entity ? !q.in_air : 1.0",
      "transformTicks": 10,
      "poseTypes": ["STAND", "NONE", "PROFILE"],
      "animations": [
        "look",
        "bedrock(vaalzebub, ground_idle)"
      ]
    },
    "walking": {
      "poseName": "walking",
	  "condition": "q.has_entity ? !q.in_air",
      "transformTicks": 10,
      "poseTypes": ["WALK"],
      "animations": [
        "bedrock(vaalzebub, ground_walk)",
        {
          "condition": "q.is_ridden",
          "animation": "q.bedrock('vaalzebub', 'ride_ground_walk')"
        }
      ]
    },
    "hovering": {
      "poseName": "hovering",
      "transformTicks": 10,
      "poseTypes": ["HOVER", "PORTRAIT"],
      "animations": [
        "look",
        "bedrock(vaalzebub, air_idle)"
      ]
    },
    "flying": {
      "poseName": "flying",
	  "condition": "!q.is_gliding",
      "transformTicks": 10,
      "poseTypes": ["FLY"],
      "animations": [
        "bedrock(vaalzebub, air_fly)",
        {
          "condition": "q.is_ridden",
          "animation": "q.bedrock('vaalzebub', 'ride_air_fly')"
        }
      ]
    },
    "glide": {
      "poseName": "glide",
      "condition": "q.is_gliding",
      "transformTicks": 10,
      "poseTypes": ["FLY"],
      "animations": [
        "bedrock(vaalzebub, air_idle)",
        {
          "condition": "q.is_ridden",
          "animation": "q.bedrock('vaalzebub', 'ride_dive')"
        }
      ]
    }
  }
}