{
  "head": "head",
  "portraitScale": 2,
  "portraitTranslation": [-0.4, 1.7, 0],
  "profileScale": 0.4,
  "profileTranslation": [0, 1.1, 0],
  "poses": {
    "standing": {
	  "poseName": "standing",
	  "poseTypes": ["STAND", "NONE", "PORTRAIT", "PROFILE", "FLOAT"],
      "condition": "q.has_entity ? !q.in_air : 1.0",
      "transformTicks": 10,
      "animations": [
		"q.look('head')",
        "q.bedrock('misteamie', 'ground_idle')"
      ]
    },
    "in_air": {
      "poseTypes": ["WALK", "STAND", "NONE"],
      "isBattle": false,
      "condition": "q.has_entity ? q.in_air && q.is_ridden : 0.0",
      "animations": [
        "q.look('head')", 
        "q.bedrock('misteamie', 'ride_jump')"
      ],
      "transformTicks": 2,
      "transformToTicks": 2
    },
    "walking": {
	  "poseName": "walking",
	  "poseTypes": ["WALK", "SWIM"],
      "condition": "q.has_entity ? !q.in_air && !q.is_sprinting : 1.0",
      "transformTicks": 10,
      "animations": [
        "q.bedrock('misteamie', 'ground_walk')",
        {
          "condition": "q.is_ridden",
          "animation": "q.bedrock('misteamie', 'ride_ground_run')"
        }
      ]
    },
    "running": {
      "poseTypes": ["WALK", "SWIM"],
      "condition": "q.has_entity ? !q.in_air && q.is_sprinting : 0.0",
      "animations": [
        "q.look('head')", 
        "q.bedrock('misteamie', 'ground_run')",
        {
          "condition": "q.is_ridden",
          "animation": "q.bedrock('misteamie', 'ride_ground_run')"
        }
      ]
    }
  }
}