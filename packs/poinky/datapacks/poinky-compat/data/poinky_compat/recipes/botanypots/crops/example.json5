{
    // Use bookshelf library to check if item exist (spam log less)
    "bookshelf:load_conditions": [
        {
            "type": "bookshelf:item_exists",
            "values": [
                "" // Seed Item [Identifier (modid:item)]
            ]
        }
    ],
    "type": "botanypots:crop", // Constant
    "seed": {
        "item": "" // Seed Item [Identifier (modid:item)]
    },
    "categories": [ // Categories from soils that this crop can grow with

    ],
    "growthTicks": 1800, // How many ticks to grow
    "display": {}, // https://github.com/Darkhax-Minecraft/BotanyPots/wiki/Datapack-Information#displaystates

    // Defaults
    "drops": [
        {
            "chance": 1.00,
            "output": {
                "item": "mod:log" // [Identifier (modid:item)]
            }, 
            "minRolls": 2, //min count
            "maxRolls": 4 //max count
        },
        {
            "chance": 0.25,
            "output": {
                "item": "minecraft:stick" // optional
            },
            "minRolls": 1,
            "maxRolls": 2
        },
        {
            "chance": 0.01,
            "output": {
                "item": "mod:sapling"
            }
        }
    ]
}